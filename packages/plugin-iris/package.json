{
  "name": "@agent-iris/plugin-iris",
  "version": "0.1.2",
  "description": "Generic iris protocol plugin client (self-connect and external integration)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "bin": {
    "plugin-iris": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "NODE_ENV=production bun build src/index.ts src/client.ts src/types.ts --outdir dist --target node --sourcemap=external --define 'process.env.NODE_ENV=\"production\"' && chmod +x dist/index.js && tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist",
    "prepublishOnly": "bun run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.3.2",
    "pino-pretty": "^13.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@agent-iris/protocol": "workspace:*",
    "@types/ws": "^8.5.13",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "iris",
    "plugin",
    "websocket",
    "gateway"
  ],
  "license": "MIT"
}
